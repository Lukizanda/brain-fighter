-- ============================================
-- CAMERA-WEAPON INTEGRATION GUIDE
-- ============================================
--
-- This document explains how CameraController is integrated
-- into the weapon state machine for dynamic camera behavior.
--
-- ============================================
-- ARCHITECTURE OVERVIEW
-- ============================================
--
-- The weapon system has a tight coupling between weapon states
-- and camera behavior. When the weapon changes state, the camera
-- automatically adjusts to match.
--
-- Flow:
-- 1. CameraManager initializes a singleton CameraController
-- 2. When a weapon equips, it receives the CameraController reference
-- 3. Weapon state transitions trigger camera mode changes
-- 4. Camera smoothly transitions between modes
--
-- ============================================
-- CONTROLLER HIERARCHY
-- ============================================
--
-- WeaponController (base — state machine, ammo, input)
--   FirearmController (shared — shoot, reload, recoil, GUI, animation, aim assist)
--
-- FirearmController reads the `cameraModeFamily` Tool attribute (e.g.
-- "Handgun" or "Rifle") and derives the mode set as <family>,
-- <family>Aiming, <family>Sprinting. Templates set the attribute in
-- their init.meta.json. Defaults to "Handgun" when unset. Tests / call
-- sites can still pass a `cameraModes` config table to override.
--
-- ============================================
-- CAMERA MODES
-- ============================================
--
-- Default: Standard third-person camera
--  - armLength: 8
--  - socketOffset: (1.0, 1.5, 0)
--  - fieldOfView: 70
--
-- Handgun: One-handed weapon equipped, idle state
--  - armLength: 10
--  - socketOffset: (3.0, 3.0, 0) - Right shoulder
--  - fieldOfView: 70
--
-- HandgunAiming: One-handed aiming down sights
--  - armLength: 8
--  - socketOffset: (2.0, 2.5, 0) - Closer to weapon
--  - fieldOfView: 50 - Zoomed in
--  - stiffness: 300 - Snappier response
--
-- HandgunSprinting: Sprinting with one-handed weapon
--  - armLength: 12 - Further back
--  - socketOffset: (2.0, 2.0, 0) - Lower position
--  - fieldOfView: 75 - Slightly wider
--  - stiffness: 150 - More lag for dynamic feel
--
-- Rifle: Two-handed weapon equipped, idle state
--  - armLength: 10
--  - socketOffset: (3.5, 3.0, 0) - Slightly wider offset
--  - fieldOfView: 70
--
-- RifleAiming: Two-handed aiming down sights
--  - armLength: 6
--  - socketOffset: (1.5, 2.5, 0) - Tighter to weapon
--  - fieldOfView: 45 - More zoomed
--  - stiffness: 300
--
-- RifleSprinting: Sprinting with two-handed weapon
--  - armLength: 14 - Further back
--  - socketOffset: (2.5, 2.0, 0)
--  - fieldOfView: 80 - Wider
--  - stiffness: 150
--
-- ============================================
-- STATE TO CAMERA MAPPING
-- ============================================
--
-- Weapon State          -> Camera Mode (varies by controller)
-- ----------------------------------------
-- Unequipped            -> Default
-- Idle                  -> {cameraModes.idle}
-- Firing                -> {cameraModes.aiming}
-- Reloading             -> {cameraModes.idle}
-- Sprinting             -> {cameraModes.sprinting}
-- Aiming                -> {cameraModes.aiming}
-- AimingFiring          -> {cameraModes.aiming}
-- AimingReloading       -> {cameraModes.aiming}
--
-- ============================================
-- IMPLEMENTATION DETAILS
-- ============================================
--
-- 1. CameraController.new() creates the singleton
-- 2. FirearmController.new() receives cameraController and cameraModes in config
-- 3. State callbacks (onEnterIdle, onEnterAiming, etc.) call
--    cameraController:setMode(self.cameraModes.idle) etc.
-- 4. CameraController smoothly interpolates between modes
--
-- ============================================
-- ADDING A NEW WEAPON CLASS
-- ============================================
--
-- To add a new weapon class (e.g., Shotgun):
--
-- 1. Add camera modes to CameraController.CameraModes (Shotgun, ShotgunAiming, ShotgunSprinting)
-- 2. Create ShotgunController extending FirearmController with those camera modes
-- 3. Create weapon templates that use ShotgunController
--
-- Example:
--
-- local FirearmController = require(script.Parent.FirearmController)
--
-- local SHOTGUN_CAMERA_MODES = {
--     idle = "Shotgun",
--     aiming = "ShotgunAiming",
--     sprinting = "ShotgunSprinting",
-- }
--
-- local ShotgunController = setmetatable({}, FirearmController)
-- ShotgunController.__index = ShotgunController
--
-- function ShotgunController.new(weapon, config)
--     config = config or {}
--     config.cameraModes = config.cameraModes or SHOTGUN_CAMERA_MODES
--     local self = FirearmController.new(weapon, config)
--     setmetatable(self, ShotgunController)
--     return self
-- end
--
-- ============================================
-- CUSTOMIZING CAMERA BEHAVIOR
-- ============================================
--
-- Camera modes can be customized by modifying:
--
-- armLength: Distance from character to camera
-- socketOffset: Position relative to character
-- fieldOfView: Zoom level (lower = more zoom)
-- stiffness: How snappy the spring is (higher = faster)
-- damping: How much bounce (higher = less bounce)
-- transitionTime: Time to switch between modes
--
-- ============================================
-- SPRING PHYSICS
-- ============================================
--
-- The camera uses spring physics for smooth movement:
--
-- SpringMode.Rigid: Instant snap, no lag
-- SpringMode.Spring: Full physics with lag and bounce
--
-- Set with: cameraController:setSpringMode("Spring" or "Rigid")
--
-- ============================================
-- THIRD-PERSON VS FIRST-PERSON
-- ============================================
--
-- This system is designed for third-person view.
-- For first-person:
--
-- 1. Set armLength to 0 or very small
-- 2. Position socketOffset at eye level
-- 3. Use ViewModelController for weapon display
-- 4. Hide character tool parts
--
-- Example first-person mode:
-- FirstPerson = {
--     name = "FirstPerson",
--     armLength = 0.5,
--     socketOffset = Vector3.new(0, 1.6, 0),
--     fieldOfView = 70,
--     transitionTime = 0.2,
-- }
--
-- ============================================

